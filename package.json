{
  "name": "@gharikishore/backlog-kit",
  "version": "0.1.0",
  "description": "Reusable backlog / intake-tracking library for Next.js + Drizzle apps. Pluggable categories, kinds, schema names, auth, and UI theme. Ships state machine + ship-gate + META-child relationships + comments + SSE-driven UI refresh.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./routes": "./src/routes/index.ts",
    "./ui": "./src/ui/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter yet'"
  },
  "keywords": [
    "nextjs",
    "drizzle",
    "backlog",
    "intake",
    "triage",
    "ship-gate",
    "audit-log"
  ],
  "author": "Hari Gunupudi <harigunupudi@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "drizzle-orm": ">=0.30",
    "lucide-react": ">=0.300.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "typescript": "^5.4"
  }
}
